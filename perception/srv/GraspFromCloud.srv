# REQUEST
# Segmented object point cloud (e.g. from obb_3d's 3D object mapping). The
# cloud's header.frame_id is used as the source frame for the TF transform to
# the planning frame — it may be any world/sensor frame (map, odom, camera…).
# Organized or unorganized; only the x/y/z float32 fields are read.
sensor_msgs/PointCloud2 cloud
float32 score_threshold         # minimum grasp quality score (0 = no filter)
int32 max_grasps                # cap on returned poses (0 = up to 20)
string planning_frame           # output frame for poses_base (empty = node's planning_frame param, default base_footprint)

# ── Optional selection preferences (soft re-rank only) ──
# GraspNet's candidates are re-ordered by a weighted score; nothing is rejected.
# Vectors/points are expressed in the planning frame. If EVERY *_weight is 0
# (the default), the response is ordered purely by GraspNet quality — i.e.
# identical to omitting all of these.
geometry_msgs/Vector3 preferred_approach  # desired approach/travel direction, e.g. (0,0,-1)=top-down
float32 approach_weight                   # weight on alignment with preferred_approach
geometry_msgs/Point   preferred_position  # desired grasp point
float32 position_weight                   # weight on closeness to preferred_position
float32 position_falloff_m                # distance scale for the position score (<=0 → 0.05 m)
float32 preferred_width                   # desired gripper opening width, metres
float32 width_weight                      # weight on matching preferred_width
float32 region_frac                       # height fraction along object: 0=bottom … 1=top
float32 region_weight                     # weight on grasping near region_frac (planning Z)
float32 quality_weight                    # weight on GraspNet's own quality score
---
# RESPONSE
# Grasp pose(s) in the planning frame: position + orientation (grasp angle).
# Identical shape to GraspFromMask so downstream arm code consumes either.
geometry_msgs/PoseArray poses_base            # grasp poses in planning frame
geometry_msgs/PoseArray approach_poses_base   # pre-grasp approach poses (backed out along approach axis)
string planning_frame                         # frame used for poses_base / approach_poses_base
float32[] scores
float32[] widths
bool success
string message
# Timing/point counts are logged to the node terminal, not returned here.

# Object bounding box in planning frame — use to build a MoveIt CollisionObject
geometry_msgs/Vector3 object_size       # AABB dimensions (x, y, z) in metres
geometry_msgs/Pose    object_bbox_pose  # centre of AABB in planning frame (identity orientation)

# Per-grasp vertical decomposition (planning frame Z = up)
float32[] height_below_grasp           # metres from object bottom to each grasp point
float32[] height_above_grasp           # metres from each grasp point to object top
