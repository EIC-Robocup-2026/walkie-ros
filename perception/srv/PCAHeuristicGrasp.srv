# REQUEST
sensor_msgs/Image         mask            # 16UC1, pixel value = tracker_id
int32                     tracker_id      # >0 selects that label; 0 = all non-zero pixels
vision_msgs/BoundingBox2D bbox            # fallback ROI when the mask is empty/sparse
int32                     num_frames      # 0 = adaptive (try 1 -> 3 -> 5 until min_points)

# YOLO class name — optional but recommended. Used to bias shape
# classification for known object types (e.g. "fork"/"spoon" force the
# elongated_flat path). Leave empty to rely on PCA geometry alone.
string                    object_class

# Parallel-jaw gripper max opening — grasps wider than this get a reduced
# score (not rejected, just flagged via the score).
float32                   max_gripper_width
---
# RESPONSE
# Mirrors GraspFromMask so downstream arm code can consume either service.
# Grasp pose(s) in the planning frame: position + orientation (grasp angle).
geometry_msgs/PoseArray poses_base            # grasp poses in planning frame
geometry_msgs/PoseArray approach_poses_base   # pre-grasp approach poses (backed out along approach axis)
string planning_frame                         # frame used for poses_base / approach_poses_base
float32[] scores                              # heuristic confidence [0,1]
float32[] widths                              # required gripper opening [m]

bool   success
string message

# Object bounding box in planning frame — use to build a MoveIt CollisionObject
geometry_msgs/Vector3 object_size       # AABB dimensions (x, y, z) in metres
geometry_msgs/Pose    object_bbox_pose  # centre of AABB in planning frame (identity orientation)

# Per-grasp vertical decomposition (planning frame Z = up)
float32[] height_below_grasp           # metres from object bottom to each grasp point
float32[] height_above_grasp           # metres from each grasp point to object top

# ── Shape-analysis debug fields ───────────────────────────────────────
string     detected_shape        # "cylindrical" | "spherical" | "elongated_flat" | "unknown"
float32[3] pca_eigenvalues        # lambda0 >= lambda1 >= lambda2
float32[9] pca_axes               # row-major 3x3, columns = principal axes
# Timing/point counts are logged to the node terminal, not returned here.
