  <gazebo reference="bottom_link">
    <sensor name="bottom_rgb_sensor" type="camera">
      <pose frame="bottom_color_optical_frame">0 0 0 0 0 0</pose>
      <camera name="bottom_color">
        <horizontal_fov>1.211258501</horizontal_fov>
        <!--69.4 deg = 1.211258501 rad -->
        <aspect_ratio>1.777777778</aspect_ratio>
        <!-- 16:9-->
        <image>
          <width>1920</width>
          <height>1080</height>
          <format>RGB_INT8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <always_on>1</always_on>
      <update_rate>2</update_rate>
      <visualize>1</visualize>
      <gz_frame_id>bottom_color_optical_frame</gz_frame_id>
      <plugin filename="libgazebo_ros_camera.so" name="bottom_color_controller">
        <alwaysOn>true</alwaysOn>
        <updateRate>0.0</updateRate>
        <cameraName>bottom/color/</cameraName>
        <imageTopicName>image_raw</imageTopicName>
        <cameraInfoTopicName>camera_info</cameraInfoTopicName>
        <frameName>bottom_color_optical_frame</frameName>
        <!--<hackBaseline>0.07</hackBaseline>-->
        <hackBaseline>0.0</hackBaseline>
        <distortionK1>0.0</distortionK1>
        <distortionK2>0.0</distortionK2>
        <distortionK3>0.0</distortionK3>
        <distortionT1>0.0</distortionT1>
        <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
    <sensor name="bottom_depth_sensor" type="depth">
      <pose frame="bottom_depth_optical_frame">0 -0.03 0.004 0 0 0</pose>
      <camera name="bottom">
        <camera_info_topic>bottom_depth/camera_info</camera_info_topic>
        <!--69.4 deg = 1.211258501 rad -->
        <horizontal_fov>1.211258501</horizontal_fov>
        <!-- 16:9-->
        <aspect_ratio>1.777777778</aspect_ratio>
        <image>
          <width>1280</width>
          <height>720</height>
        </image>
        <clip>
          <near>0.1</near>
          <far>8</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.010</stddev>
        </noise>
      </camera>
      <always_on>1</always_on>
      <update_rate>2</update_rate>
      <visualize>true</visualize>
      <topic>bottom_depth/image</topic>
      <gz_frame_id>bottom_depth_frame</gz_frame_id>
      <plugin filename="libgazebo_ros_camera.so" name="{name}_depth_controller">
